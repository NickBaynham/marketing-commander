# Marketing Commander environment configuration.
# Copy to .env and adjust. Never commit .env or real secrets (CLAUDE.md).
# Variables are grouped by the phase that starts using them.

# --- Core (Phase 2+) ---
# Environment name: local | test | ci (Technical Design, Section 8)
MC_ENV=local
# Session-cookie Secure flag. Unset: derived from MC_ENV (off for local,
# on otherwise). Set to true explicitly behind TLS; must be true in any
# non-local deployment (REQ-053, D8-2).
# SESSION_COOKIE_SECURE=true

# --- PostgreSQL (Phase 3+) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=marketing_commander
POSTGRES_USER=mc_app
POSTGRES_PASSWORD=change-me-locally

# --- Redis (Phase 3+) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- Auth (Phase 8+, D8-3/D8-5) ---
# The seeded owner's local dev password; `make seed` sets it as the
# owner's credential. Change locally; never commit a real value.
LOCAL_OWNER_PASSWORD=change-me-locally

# --- Service ports (Phase 3+) ---
WEB_PORT=3000
API_PORT=8000

# --- LLM provider (Phase 9+, DEC-06 / DEC-10) ---
# mock is the default everywhere; live provider use requires explicit
# opt-in and the DEC-10 privacy requirements.
LLM_PROVIDER=mock
LLM_MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=

# --- Cost caps (Phase 9+, DEC-06; environment-configurable, no permanent
# --- dollar values in documents) ---
LLM_MAX_INPUT_TOKENS=20000
LLM_MAX_OUTPUT_TOKENS=8000
LLM_MAX_COST_PER_RUN_USD=1.00
LLM_MAX_COST_PER_CAMPAIGN_USD=10.00
LLM_MONTHLY_WORKSPACE_BUDGET_USD=25.00
